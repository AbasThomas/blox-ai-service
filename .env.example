# Core
NODE_ENV=development
PORT=3333
REALTIME_PORT=3335
AI_SERVICE_PORT=3334
APP_BASE_URL=http://localhost:4200
APP_URL=http://localhost:4200
API_BASE_URL=http://localhost:3333
NEXT_PUBLIC_APP_BASE_URL=http://localhost:4200
NEXT_PUBLIC_API_BASE_URL=http://localhost:3333
AI_SERVICE_URL=http://localhost:3334

# Datastoresa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=blox
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blox-redis
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://localhost:27017/blox-mongo

# Auth
JWT_ACCESS_SECRET=replace-with-at-least-32-chars-access
JWT_REFRESH_SECRET=replace-with-at-least-32-chars-refresh
CORS_ORIGIN=http://localhost:4200,http://localhost:3000

# OAuth Integrations (optional; app falls back to manual import if unset)
# Local dev helper: when true, all providers connect in fallback mode (no external OAuth redirects)
FORCE_LOCAL_INTEGRATIONS=true

# ── LinkedIn ───────────────────────────────────────────────────────────────
# Scopes: openid profile email
# Callback URI: http://localhost:3333/v1/auth/oauth/linkedin/callback
# Docs: https://learn.microsoft.com/en-us/linkedin/shared/authentication/authorization-code-flow
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── GitHub ─────────────────────────────────────────────────────────────────
# Scopes: read:user user:email repo
# Callback URI: http://localhost:3333/v1/auth/oauth/github/callback
# Docs: https://docs.github.com/en/apps/oauth-apps/building-oauth-apps/creating-an-oauth-app
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Upwork ─────────────────────────────────────────────────────────────────
# Scopes: freelancer.profile.read
# Callback URI: http://localhost:3333/v1/auth/oauth/upwork/callback
# Docs: https://developers.upwork.com/?lang=node#authentication_oauth-20
UPWORK_CLIENT_ID=
UPWORK_CLIENT_SECRET=
# Upwork GraphQL API endpoint (override if using a proxy)
UPWORK_GRAPHQL_URL=https://www.upwork.com/api/graphql/v1

# ── Figma ──────────────────────────────────────────────────────────────────
# Scopes: file_read
# Callback URI: http://localhost:3333/v1/auth/oauth/figma/callback
# Docs: https://www.figma.com/developers/api#oauth2
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=

# ── Dribbble ───────────────────────────────────────────────────────────────
# Scopes: public
# Callback URI: http://localhost:3333/v1/auth/oauth/dribbble/callback
# Docs: https://developer.dribbble.com/v2/oauth/
DRIBBBLE_CLIENT_ID=
DRIBBBLE_CLIENT_SECRET=

# ── Canva ──────────────────────────────────────────────────────────────────
# Scopes: profile:read design:meta:read
# Callback URI: http://localhost:3333/v1/auth/oauth/canva/callback
# Docs: https://www.canva.com/developers/docs/connect/
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Manual-only integrations (no public OAuth API available):
# - Fiverr  (no public OAuth)
# - Behance (Adobe deprecated public API in 2022)
# - Coursera (no user-level OAuth for certificates)
# - Udemy   (course catalog API only, no personal OAuth)

# AI
BLOX_AI_DRY_RUN=true
HUGGING_FACE_TOKEN=

# Payments
PAYSTACK_SECRET_KEY=sk_test_replace
PAYSTACK_PUBLIC_KEY=pk_test_replace
PAYSTACK_WEBHOOK_SECRET=whsec_replace

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

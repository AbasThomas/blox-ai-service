# OAuth Integrations (optional; app falls back to manual import if unset)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
UPWORK_CLIENT_ID=
UPWORK_CLIENT_SECRET=
DRIBBBLE_CLIENT_ID=
DRIBBBLE_CLIENT_SECRET=
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
UPWORK_GRAPHQL_URL=https://www.upwork.com/api/graphql/v1

# OAuth callback + local mode
API_BASE_URL=http://localhost:3333
FORCE_LOCAL_INTEGRATIONS=true

# Manual-only providers (no OAuth keys required): coursera, udemy, behance, fiverr
Callback URL format is:
                                                     
  {API_BASE_URL}/v1/auth/oauth/{provider}/callback   
                                                     
  With your current local settings                   
  (API_BASE_URL=http://localhost:3333), use:         
                                                     
  -                                                  
  http://localhost:3333/v1/auth/oauth/linkedin/callback                                                   
  -                                                  
  http://localhost:3333/v1/auth/oauth/github/callback  -                                                  
  http://localhost:3333/v1/auth/oauth/upwork/callback
  -                                                  
  http://localhost:3333/v1/auth/oauth/dribbble/callback                                                   
  -                                                  
  http://localhost:3333/v1/auth/oauth/canva/callback 
  -                                                  
  http://localhost:3333/v1/auth/oauth/figma/callback 
                                                     
  For production, replace the base with your public  
  API domain, for example                            
  https://api.yourdomain.com/v1/auth/oauth/github/callback.                                               
 